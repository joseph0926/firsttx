{
  "name": "playground",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "description": "Interactive playground demonstrating FirstTx through 9 real-world scenarios. Experience how FirstTx solves CSR challenges like blank screens, stale data, and rollback inconsistencies.",
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "typecheck": "tsc -b",
    "lint": "eslint .",
    "preview": "vite preview",
    "test:e2e": "playwright test",
    "metrics:sync": "node ./scripts/sync-metrics.mjs"
  },
  "dependencies": {
    "@firsttx/local-first": "workspace:*",
    "@firsttx/prepaint": "workspace:*",
    "@firsttx/tx": "workspace:*",
    "@tailwindcss/vite": "^4.1.18",
    "@vercel/analytics": "^1.5.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^0.563.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-router": "^7.13.0",
    "rosetta": "^1.1.0",
    "tailwind-merge": "^3.3.1",
    "tailwindcss": "^4.1.18",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.58.2",
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^10.1.0",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "tw-animate-css": "^1.4.0",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.57.2",
    "vite": "^8.0.3"
  }
}
